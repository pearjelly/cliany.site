{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cliany-site explain v1",
  "type": "object",
  "required": ["schema_version", "binary", "version", "commands", "error_codes"],
  "properties": {
    "schema_version": {"type": "string", "const": "1"},
    "binary": {"type": "string"},
    "version": {"type": "string"},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {"type": "string"},
          "source": {"type": "string", "enum": ["builtin", "atom", "adapter"]},
          "params": {"type": "array"},
          "returns": {"type": "object"},
          "examples": {"type": "array"}
        }
      }
    },
    "error_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "hint": {"type": ["string", "null"]}
        }
      }
    }
  }
}