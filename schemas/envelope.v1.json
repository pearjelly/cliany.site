{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "version": {
      "type": "string",
      "const": "1"
    },
    "command": {
      "type": "string"
    },
    "data": {},
    "error": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "hint": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "string"
                }
              ]
            },
            "details": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "object"
                }
              ]
            }
          },
          "required": ["code", "message", "hint", "details"]
        }
      ]
    },
    "meta": {
      "type": "object",
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string",
          "enum": ["builtin", "atom", "adapter"]
        }
      },
      "required": ["duration_ms", "source"]
    }
  },
  "required": ["ok", "version", "command", "data", "error", "meta"]
}